#tag Events ListboxRaces
	#tag Event
		Function CellPressed(row As Integer, column As Integer, x As Integer, y As Integer) As Boolean
		  if column = 0 then
		    
		    'tf_RaceInfo.Text = "Race #"+str(row+1)+" : " + me.CellTextAt(row,1)
		    '
		    'if left(me.CellTextAt(row,2),7) ="Winner " then
		    'if me.CellTextAt(val(right(me.CellTextAt(row,2),2))-1,4) > "" then
		    'me.CellTextAt(row,2) = me.CellTextAt(val(right(me.CellTextAt(row,2),2))-1,4)
		    'drBoard.RaceSchedule(row).Lane1.cName = me.CellTextAt(row,2)
		    ''drBoard.RaceSchedule(row).Lane1.Contestant_no = 
		    'end if
		    'end if
		    '
		    'if left(me.CellTextAt(row,3),7) ="Winner " then
		    ''if me.CellTextAt(val(right(me.CellTextAt(row,3),2))-1,4) > "" then
		    ''me.CellTextAt(row,3) = me.CellTextAt(val(right(me.CellTextAt(row,3),2))-1,4)
		    ''end if
		    ''me.CellTextAt(row,3) = me.CellTextAt(me.CellTagAt(row,3),2))-1,4)
		    '
		    'end if
		    
		    
		    
		    'tf_Winner.Text = me.CellTextAt(row,4)
		    'tf_Racer_1.Text = me.CellTextAt(row,2)
		    'tf_Racer_2.Text = me.CellTextAt(row,3)
		    
		    drBoard.curRace = row
		    drBoard.update_ScoreBoard
		    
		    
		  end if
		End Function
	#tag EndEvent
#tag EndEvents
#tag Events ListboxRaces1
	#tag Event
		Function CellPressed(row As Integer, column As Integer, x As Integer, y As Integer) As Boolean
		  if column = 0 then
		    
		    tf_RaceInfo.Text = "Race #"+str(row+1)+" : " + me.CellTextAt(row,1)
		    
		    if left(me.CellTextAt(row,2),7) ="Winner " then
		      if me.CellTextAt(val(right(me.CellTextAt(row,2),2))-1,4) > "" then
		        me.CellTextAt(row,2) = me.CellTextAt(val(right(me.CellTextAt(row,2),2))-1,4)
		      end if
		    end if
		    
		    if left(me.CellTextAt(row,3),7) ="Winner " then
		      if me.CellTextAt(val(right(me.CellTextAt(row,3),2))-1,4) > "" then
		        me.CellTextAt(row,3) = me.CellTextAt(val(right(me.CellTextAt(row,3),2))-1,4)
		      end if
		    end if
		    
		    
		    tf_Winner.Text = me.CellTextAt(row,4)
		    tf_Racer_1.Text = me.CellTextAt(row,2)
		    tf_Racer_2.Text = me.CellTextAt(row,3)
		    
		    drBoard.curRace = row
		    
		    
		  end if
		End Function
	#tag EndEvent
#tag EndEvents

	#tag Event
		Function CellPressed(row As Integer, column As Integer, x As Integer, y As Integer) As Boolean
		  if column = 0 then
		    
		  else
		    me.EditCellAt(row,column)
		    currentlyEditing = row
		    
		  end if
		  
		End Function
	#tag EndEvent
	#tag Event
		Sub FocusLost()
		  drBoard.ContestantRacer(currentlyEditing).name = me.CellTextAt(currentlyEditing,1)
		  
		End Sub

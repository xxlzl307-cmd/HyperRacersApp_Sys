	#tag Method, Flags = &h0
		Sub HRDBReload()
		  ' Reload all data from Supabase and repopulate listboxes
		  LoadMembers
		  LoadTournaments
		  LoadRaceDays
		  LoadRaceEvents
		  
		  ' Repopulate Members list
		  lbMembers.RemoveAllRows
		  Var lm As Integer
		  For lm = 0 To app.LeagueMembers.LastIndex
		    lbMembers.AddRow(str(app.LeagueMembers(lm).id), app.LeagueMembers(lm).name)
		  Next
		  
		  ' Repopulate Tournaments list
		  lbTournamentsList.RemoveAllRows
		  For lm = 0 To app.LeagueTournaments.LastIndex
		    lbTournamentsList.AddRow(str(app.LeagueTournaments(lm).id), app.LeagueTournaments(lm).name)
		  Next
		  
		  ' Repopulate RaceDay list
		  lbRaceDay.RemoveAllRows
		  For lm = 0 To app.LeagueRaceDays.LastIndex
		    lbRaceDay.AddRow(str(app.LeagueRaceDays(lm).id), app.LeagueRaceDays(lm).name)
		  Next
		  
		End Sub
	#tag EndMethod

#tag EndWindowCode


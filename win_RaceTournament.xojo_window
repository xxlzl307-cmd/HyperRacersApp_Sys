		Sub DropObjectOnRow(x As Integer, y As Integer, obj As DragItem, action As Integer, row As Integer, parentRow As Integer, location As DesktopListbox.DropLocations)
		  var data() as String
		  data = obj.Text.Split(":")
		  Me.CellTextAt (row,1) = data(1) 'Name
		  Me.CellTextAt (row,3) = data(0) 'member_id
		  
		  currentTournament.Contestants(me.CellTextAt(row,0).ToInteger).member_id = data(0).ToInteger
		  currentTournament.Contestants(me.CellTextAt(row,0).ToInteger).name = data(1)
		  
		  
		End Sub

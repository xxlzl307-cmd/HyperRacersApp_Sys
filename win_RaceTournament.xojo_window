		  Dim t, d, x, y, z, r  As Integer
		  
		  
		  ListBoxSched.HeaderAt(0) = "Racer"
		  ListBoxSched.HeaderAt(1) = "Heat"
		  ListBoxSched.HeaderAt(2) = "Race"
		  ListBoxSched.HeaderAt(3) = "Time"
		  ListBoxSched.HeaderAt(4) = "Laps"
		  ListBoxSched.HeaderAt(5) = "Place"
		  ListBoxSched.HeaderAt(6) = "Points"
		  ListBoxSched.HeaderAt(7) = "Prize"
		  ListBoxSched.HeaderAt(8) = "Value"
		  ListBoxSched.HeaderAt(9) = "ndx"
		  
		  ListBoxSched.RemoveAllRows
		  lbContestant.RemoveAllRows
		  lbTournaments.RemoveAllRows
		  lbRacers.RemoveAllRows
		  
		  
		  
		  'win_RaceShedule.ListBoxSched.AddRow("Name", "2", "time", "laps")
		  'for x = 0 to currentRace(0).Racestats.LastIndex
		  currentRound = win_HyperRace.currentRound
		  
		  
		  For d = 0 To win_HyperRace.currentRaceTournament.LastIndex '///////////////Tournaments
		    currentTournament = win_HyperRace.currentRaceTournament(d)
		    ListBoxSched.AddRow(currentTournament.name)
		    lbTournaments.AddRow(str(d), currentTournament.name)
		    
		    Label_tournament.text =  currentTournament.name
		    
		    For cnts As Integer = 0 To currentTournament.Contestants.LastIndex
		      lbContestant.AddRow(Str(cnts),currentTournament.Contestants(cnts).name, currentTournament.name,currentTournament.Contestants(cnts).score.ToString ,currentTournament.Contestants(cnts).member_id.ToString)
		    Next
		    
		    If currentTournament.RaceEvents.LastIndex >= 0 Then
		      If currentTournament.RaceEvents(0).Rounds.LastIndex >= 0 Then
		        For rcr As Integer = 0 To currentTournament.RaceEvents(0).Rounds(0).Racers.LastIndex
		          lbRacers.AddRow(str(rcr), currentTournament.RaceEvents(0).Rounds(0).Racers(rcr).name, currentTournament.RaceEvents(0).Rounds(0).Racers(rcr).place.ToString, currentTournament.RaceEvents(0).Rounds(0).Racers(rcr).points.ToString, currentTournament.RaceEvents(0).Rounds(0).Racers(rcr).totalTime.ToString, "$"+currentTournament.RaceEvents(0).Rounds(0).Racers(rcr).value.ToString)
		        Next
		      End If
		    End If
		    
		    
		    lbRaceDates.RemoveAllRows
		    For rd As Integer = 0 To currentTournament.RaceEvents.LastIndex'///////////RaceEvents - RaceDates
		      lbRaceDates.AddRow(currentTournament.RaceEvents(rd).id.ToString,currentTournament.RaceEvents(rd).name)
		      'RacerListbox.AddRow(Str(rd), currentTournament.RaceEvents(rd).name)
		      
		      For cnts As Integer = 0 To currentTournament.RaceEvents(rd).Contestants.LastIndex
		        currentTournament.RaceEvents(rd).Contestants(cnts).name = currentTournament.Contestants(cnts).name
		        currentTournament.RaceEvents(rd).Contestants(cnts).memberID = currentTournament.Contestants(cnts).xid.Member
		        'currentTournament.Contestants(cnts).name = currentTournament.Contestants(cnts).name
		        'currentTournament.Contestants(cnts).xid.Member = currentTournament.Contestants(cnts).member_id
		        
		        ListBoxSched.AddRow(currentTournament.RaceEvents(rd).Contestants(cnts).name + " " + currentTournament.Contestants(cnts).name)
		      Next
		      
		      
		      
		      For rnds As Integer = 0 To currentTournament.RaceEvents(rd).Rounds.LastIndex'///////////RaceRounds- Rounds
		        Var rndName As String
		        ListBoxSched.AddRow(currentTournament.RaceEvents(rd).Rounds(rnds).name)
		        'rndName  = currentTournament.RaceEvents(rd).Rounds(rnds).name
		        ListBoxSched.AddRow(rndName +" "+ currentTournament.name + If(currentTournament.info <> Nil, " < "+currentTournament.info.raceClass+" >", ""))
		        
		        
		        'For cnts As Integer = 0 To currentTournament.RaceEvents(rd).Rounds(rnds).Contestants.LastIndex
		        For cnts As Integer = 0 To currentTournament.Contestants.LastIndex
		          currentTournament.RaceEvents(rd).Rounds(rnds).Contestants(cnts).name = currentTournament.Contestants(cnts).name
		          currentTournament.RaceEvents(rd).Rounds(rnds).Contestants(cnts).memberID = currentTournament.Contestants(cnts).xid.Member
		          
		          ListBoxSched.AddRow(currentTournament.RaceEvents(rd).Rounds(rnds).Contestants(cnts).name + " " + currentTournament.Contestants(cnts).name)
		        Next
		        
		        
		        'For qr As Integer = 0 To 1'currentTournament.RaceEvents(rd).Rounds(rnds).Qualifier. '///////////QualifierHeats - Races
		        ListBoxSched.AddRow(rndName +"<Q> "+ currentTournament.RaceEvents(rd).Rounds(rnds).Qualifier.name)
		        
		        
		        For qrc As Integer = 0 To currentTournament.RaceEvents(rd).Rounds(rnds).Qualifier.Races.LastIndex
		          ListBoxSched.AddRow(rndName +" <QR >    "+ currentTournament.RaceEvents(rd).Rounds(rnds).Qualifier.Races(qrc).name )
		          
		          
		          For x = 0 To currentTournament.RaceEvents(rd).Rounds(rnds).Qualifier.Races(qrc).RaceStats.LastIndex
		            
		            ListBoxSched.AddRow(currentTournament.RaceEvents(rd).Rounds(rnds).Qualifier.Races(qrc).RaceStats(x).Racer + " " + currentTournament.Contestants(currentTournament.RaceEvents(rd).Rounds(rnds).Qualifier.Races(qrc).RaceStats(x).Contestant_id).name)
		            
		            ListBoxSched.CellTextAt(ListBoxSched.LastAddedRowIndex, 1) = Str(currentTournament.RaceEvents(rd).Rounds(rnds).Qualifier.Races(qrc).RaceStats(x).heat + 1 )
		            ListBoxSched.CellTextAt(ListBoxSched.LastAddedRowIndex, 2) = Str(currentTournament.RaceEvents(rd).Rounds(rnds).Qualifier.Races(qrc).RaceStats(x).raceNo +1 ) 
		            ListBoxSched.CellTextAt(ListBoxSched.LastAddedRowIndex, 3) = currentTournament.RaceEvents(rd).Rounds(rnds).Qualifier.Races(qrc).RaceStats(x).Time.ToString 
		            ListBoxSched.CellTextAt(ListBoxSched.LastAddedRowIndex, 4) = currentTournament.RaceEvents(rd).Rounds(rnds).Qualifier.Races(qrc).RaceStats(x).laps.ToString 
		            ListBoxSched.CellTextAt(ListBoxSched.LastAddedRowIndex, 5) = currentTournament.RaceEvents(rd).Rounds(rnds).Qualifier.Races(qrc).RaceStats(x).Place.ToString 
		            ListBoxSched.CellTextAt(ListBoxSched.LastAddedRowIndex, 6) = currentTournament.RaceEvents(rd).Rounds(rnds).Qualifier.Races(qrc).RaceStats(x).Points.ToString 
		            
		            ListBoxSched.CellTextAt(ListBoxSched.LastAddedRowIndex, 7) = currentTournament.RaceEvents(rd).Rounds(rnds).Qualifier.Races(qrc).RaceStats(x).prize.ToText
		            ListBoxSched.CellTextAt(ListBoxSched.LastAddedRowIndex, 8) = currentTournament.RaceEvents(rd).Rounds(rnds).Qualifier.Races(qrc).RaceStats(x).prizeValue.ToString
		            
		            ListBoxSched.CellTextAt(ListBoxSched.LastAddedRowIndex, 9) = currentTournament.RaceEvents(rd).Rounds(rnds).Qualifier.Races(qrc).RaceStats(x).ndx.ToString 
		            
		          Next x
		        Next qrc
		         

		        For rcrs As Integer = 0 To currentTournament.RaceEvents(rd).Rounds(rnds).Racers.LastIndex
		          ListBoxSched.AddRow(rndName +"  <q*>      "+ currentTournament.RaceEvents(rd).Rounds(rnds).Racers(rcrs).name+ " " + currentTournament.Contestants(currentTournament.RaceEvents(rd).Rounds(rnds).Racers(rcrs).Contestant_ndx).name, currentTournament.RaceEvents(rd).Rounds(rnds).Racers(rcrs).points.ToString)
		          
		        Next

		        
		        
		        'For sch As Integer = 0 To currentTournament.RaceEvents(rd).Rounds(rnds).RaceSchedules.LastIndex'///////////RaceSchedules - Races
		        
		        'currentRound = currentTournament.RaceEvents(rd).Rounds(rnds).RaceSchedules(sch)
		        
		        
		        For y = 0 To currentTournament.RaceEvents(rd).Rounds(rnds).Heats.LastIndex '///////////Heats - Races
		          ListBoxSched.AddRow(rndName +"<H> "+ currentTournament.RaceEvents(rd).Rounds(rnds).Heats(y).name)
		          
		          For rcrs As Integer = 0 To currentTournament.RaceEvents(rd).Rounds(rnds).Heats(y).Racers.LastIndex
		            ListBoxSched.AddRow(rndName + "     r*>   " + currentTournament.RaceEvents(rd).Rounds(rnds).Heats(y).Racers(rcrs).name +" "+ currentTournament.RaceEvents(rd).Rounds(rnds).Racers(rcrs).name+ " " + currentTournament.Contestants(currentTournament.RaceEvents(rd).Rounds(rnds).Racers(rcrs).Contestant_ndx).name)
		            
		            ListBoxSched.CellTextAt(ListBoxSched.LastAddedRowIndex, 3) = currentTournament.RaceEvents(rd).Rounds(rnds).Heats(y).Racers(rcrs).totalTime.ToString 
		            ListBoxSched.CellTextAt(ListBoxSched.LastAddedRowIndex, 4) = currentTournament.RaceEvents(rd).Rounds(rnds).Heats(y).Racers(rcrs).wins.ToString 
		            
		            ListBoxSched.CellTextAt(ListBoxSched.LastAddedRowIndex, 5) = currentTournament.RaceEvents(rd).Rounds(rnds).Heats(y).Racers(rcrs).place.ToString 
		            ListBoxSched.CellTextAt(ListBoxSched.LastAddedRowIndex, 6) = currentTournament.RaceEvents(rd).Rounds(rnds).Heats(y).Racers(rcrs).Points.ToString
		            ListBoxSched.CellTextAt(ListBoxSched.LastAddedRowIndex, 8) = currentTournament.RaceEvents(rd).Rounds(rnds).Heats(y).Racers(rcrs).value.ToString
		            
		          Next

		          
		          For r = 0 To currentTournament.RaceEvents(rd).Rounds(rnds).Heats(y).Races.LastIndex '///////////Heats - Races
		            ListBoxSched.AddRow(rndName +" <R>  "+ currentTournament.RaceEvents(rd).Rounds(rnds).Heats(y).Races(r).name)
		            
		            For x = 0 To currentTournament.RaceEvents(rd).Rounds(rnds).Heats(y).Races(r).Racestats.LastIndex
		              ListBoxSched.AddRow(currentTournament.RaceEvents(rd).Rounds(rnds).Heats(y).Races(r).Racestats(x).Racer  + " " + currentTournament.RaceEvents(rd).Rounds(rnds).Racers(x).name+ " " + currentTournament.Contestants(currentTournament.RaceEvents(rd).Rounds(rnds).Racers(x).Contestant_ndx).name)
		              
		              ListBoxSched.CellTextAt(ListBoxSched.LastAddedRowIndex, 1) = Str(currentTournament.RaceEvents(rd).Rounds(rnds).Heats(y).Races(r).RaceStats(x).heat + 1 )
		              ListBoxSched.CellTextAt(ListBoxSched.LastAddedRowIndex, 2) = Str(currentTournament.RaceEvents(rd).Rounds(rnds).Heats(y).Races(r).RaceStats(x).raceNo +1 ) 
		              ListBoxSched.CellTextAt(ListBoxSched.LastAddedRowIndex, 3) = currentTournament.RaceEvents(rd).Rounds(rnds).Heats(y).Races(r).RaceStats(x).Time.ToString 
		              ListBoxSched.CellTextAt(ListBoxSched.LastAddedRowIndex, 4) = currentTournament.RaceEvents(rd).Rounds(rnds).Heats(y).Races(r).raceStats(x).laps.ToString 
		              
		              ListBoxSched.CellTextAt(ListBoxSched.LastAddedRowIndex, 5) = currentTournament.RaceEvents(rd).Rounds(rnds).Heats(y).Races(r).RaceStats(x).Place.ToString 
		              ListBoxSched.CellTextAt(ListBoxSched.LastAddedRowIndex, 6) = currentTournament.RaceEvents(rd).Rounds(rnds).Heats(y).Races(r).RaceStats(x).Points.ToString 
		              
		              ListBoxSched.CellTextAt(ListBoxSched.LastAddedRowIndex, 7) = currentTournament.RaceEvents(rd).Rounds(rnds).Heats(y).Races(r).RaceStats(x).prize.ToText
		              ListBoxSched.CellTextAt(ListBoxSched.LastAddedRowIndex, 8) = currentTournament.RaceEvents(rd).Rounds(rnds).Heats(y).Races(r).RaceStats(x).prizeValue.ToString
		               
		              ListBoxSched.CellTextAt(ListBoxSched.LastAddedRowIndex, 9) = currentTournament.RaceEvents(rd).Rounds(rnds).Heats(y).Races(r).RaceStats(x).win.ToString 
		              
		            Next x
		          Next r
		        Next y
		        'Next sch
		      Next rnds
		    Next rd
		  Next d
		  
		  
		  '
		  'for x = 0 to currentRound.Heats(y).Races(r).Racestats.LastIndex
		  '
		  'win_RaceShedule.ListBoxSched.AddRow(currentRound.Heats(y).Races(r).Racestats(x).Racer)
		  'win_RaceShedule.ListBoxSched.CellTextAt(win_RaceShedule.ListBoxSched.LastAddedRowIndex, 1) = str(currentRace(0).Racestats(x).heat + 1 )
		  'win_RaceShedule.ListBoxSched.CellTextAt(win_RaceShedule.ListBoxSched.LastAddedRowIndex, 2) = str(currentRace(0).Racestats(x).raceNo +1 ) 
		  'win_RaceShedule.ListBoxSched.CellTextAt(win_RaceShedule.ListBoxSched.LastAddedRowIndex, 3) = currentRace(0).Racestats(x).Time.ToString 
		  'win_RaceShedule.ListBoxSched.CellTextAt(win_RaceShedule.ListBoxSched.LastAddedRowIndex, 4) = currentRace(0).Racestats(x).laps.ToString 
		  'win_RaceShedule.ListBoxSched.CellTextAt(win_RaceShedule.ListBoxSched.LastAddedRowIndex, 5) = currentRace(0).Racestats(x).Place.ToString 
		  'win_RaceShedule.ListBoxSched.CellTextAt(win_RaceShedule.ListBoxSched.LastAddedRowIndex, 6) = currentRace(0).Racestats(x).Points.ToString 
		  '
		  'win_RaceShedule.ListBoxSched.CellTextAt(win_RaceShedule.ListBoxSched.LastAddedRowIndex, 7) = currentRace(0).Racestats(x).ndx.ToString 
		  '
		  'next
		  '
		  'If currentRound.data_id > 0 then
		  'UpdateSchedule_data()
		  'End If
		  
		End Sub
	#tag EndMethod



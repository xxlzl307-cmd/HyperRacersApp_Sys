	#tag Event
		Sub DoublePressed()
		  currentTournament = new RaceTournament
		  currentTournament = LoadTournament(me.CellTextAt(me.SelectedRowIndex,0).ToInteger)
		  'LoadSchedulerDataBase(me.CellTextAt(me.SelectedRowIndex,0).ToInteger)
		  
		  win_HyperRace.currentRaceTournament.add(currentTournament)
		  win_HyperRace.currentRound = new RaceRound
		  
		  ' Guard against empty arrays from Supabase load
		  If win_HyperRace.currentRaceTournament.LastIndex >= 0 Then
		    win_HyperRace.currentTournament = win_HyperRace.currentRaceTournament(0)
		    If win_HyperRace.currentRaceTournament(0).RaceEvents.LastIndex >= 0 Then
		      If win_HyperRace.currentRaceTournament(0).RaceEvents(0).Rounds.LastIndex >= 0 Then
		        win_HyperRace.RaceSchedules = win_HyperRace.currentRaceTournament(0).RaceEvents(0).Rounds(0).RaceSchedules
		        win_HyperRace.currentRound = win_HyperRace.currentRaceTournament(0).RaceEvents(0).Rounds(0)
		        win_HyperRace.pmSchedules.AddRow(win_HyperRace.currentRaceTournament(0).RaceEvents(0).Rounds(0).name)
		        win_HyperRace.Label_time.Text = "0:00"
		        win_LeaderBoard.Label_time.Text = "0:00"
		        win_HyperRace.currentRound.info = currentTournament.info
		        If win_HyperRace.currentRound.Heats.LastIndex >= 0 Then
		          If win_HyperRace.currentRound.Heats(0).Races.LastIndex >= 0 Then
		            win_HyperRace.SelectRace(win_HyperRace.currentRound.Heats(0).Races(0))
		          End If
		        End If
		      End If
		    End If
		  End If
		  'win_HyperRace.SelectRace(win_HyperRace.currentTournament.RaceEvents(0).Rounds(0).Qualifier.Races(0))
		  if win_HyperRace.racers.LastIndex <0 then
		    win_HyperRace.NewRacers
		  end if
		  
		  
		  win_HyperRace.UpdateSchedule_win
		  win_HyperRace.UpdateScoreBoard
		  UpdateSchedule_win
		  
		  
		  'currentTournament = currentRaceTournament(0)
		  '
		  'RaceSchedules  = currentRaceTournament(0).RaceEvents(0).Rounds(0).RaceSchedules'=.Add(rSchedule)
		  'currentRound = currentRaceTournament(0).RaceEvents(0).Rounds(0).RaceSchedules(0)
		  'win_HyperRace.pmSchedules.AddRow(rSchedule.name)
		  '
		  'Label_time.Text ="0:00"
		  'win_LeaderBoard.Label_time.Text ="0:00"
		  '
		  'SelectRace(currentRound.Heats(0).Races(0))
		  
		End Sub
	#tag EndEvent

	#tag Method, Flags = &h0
		Function LoadSchedulerDataBase(TournamentID as Integer) As RaceTournament
		  xScheduler = New RaceScheduler
		  
		  
		  win_HyperRace.currentTournament = LoadTournament(TournamentID)
		  win_HyperRace.raceSchedule_counter = win_HyperRace.raceSchedule_counter + 1
		  
		  xScheduler =  win_HyperRace.currentTournament.info
		  //-------Races
		  
		  cbTournaments.Text = str(xScheduler.Tournamnets)
		  cbRaceClass.Text = xScheduler.raceClass 
		  cbDates.Text = str(xScheduler.dates)
		  cbNoContestans.Text = str(xScheduler.contestants)
		  cbRounds.Text = str(xScheduler.rounds)
		  cbqualifiers.Text = str(xScheduler.qualifiers)
		  cbqualType.Text = str(xScheduler.qualifiersType)
		  cbHeats.Text = str(xScheduler.heats)
		  cbRaces.Text = str(xScheduler.races)
		  cbLaps.Text = str(xScheduler.laps)
		  cbTime.Index  = xScheduler.run_time '/ 60 
		  cbNoRacers.Text = str(xScheduler.Racers) 
		  
		  if  xScheduler.timed = true then
		     cbRaceType.Text = "Timed"
		  else
		    cbRaceType.Text = "Laps"
		  end if
		  //-------Tournament
		  'xScheduler.Tournamnets = cbTournaments.Text.ToInteger
		  'xScheduler.raceClass = cbRaceClass.Text
		  'xScheduler.dates = cbDates.Text.ToInteger
		  'xScheduler.contestants = cbNoContestans.Text.ToInteger
		  'xScheduler.rounds = cbRounds.Text.ToInteger
		  'xScheduler.qualifiers = cbqualifiers.Text.ToInteger
		  'xScheduler.qualifiersType = cbqualType.Text
		  'xScheduler.heats = cbHeats.Text.ToInteger
		  'xScheduler.races = cbRaces.Text.ToInteger
		  'xScheduler.laps = cbLaps.Text.ToInteger
		  'xScheduler.run_time = cbTime.Index * 60 
		  'xScheduler.Racers = cbNoRacers.Text.ToInteger
		  
		  
		  'rScheduler.timed =  
		  
		  'xScheduler.Racers = RacerListbox.LastRowIndex+1
		  
		  'if name <> "" then
		  'xScheduler.name = Name
		  'xScheduler.description = "HyperRacers @  " + DateTime.Now.SQLDateTime
		  '
		  'else
		  'xScheduler.name = "HyperRacers " + Str(win_HyperRace.raceSchedule_counter)
		  'xScheduler.description = "Race Schedule created @  " + DateTime.Now.SQLDateTime
		  '
		  'end if
		  
		  If win_HyperRace.racers.LastIndex <0 Then
		    win_HyperRace.NewRacers
		  end if
		  
		  'win_HyperRace.NewScheduleTounament(xScheduler)        '(cbHeats.Text.ToInteger,cbRaces.Text.ToInteger,RacerListbox.LastRowIndex+1)
		  
		  
		  'vHeat.Text = "1"
		  'vRace.Text = "1"
		  'vRound.Text = "1"
		  'vDay.Text = "1"
		  'vQualifier.Text = "1"
		  'UpdateSchedule_win
		  return win_HyperRace.currentTournament
		End Function
	#tag EndMethod

	#tag Method, Flags = &h0
		Sub NewScheduler(optional Name As String)
		  xScheduler = New RaceScheduler
		  
		  
		  win_HyperRace.raceSchedule_counter = win_HyperRace.raceSchedule_counter+ 1
		  //-------Session ---------
		  
		  //-------Tournament
		  xScheduler.Tournamnets = cbTournaments.Text.ToInteger
		  xScheduler.raceClass = cbRaceClass.SelectedRowText
		  xScheduler.dates = cbDates.Text.ToInteger
		  xScheduler.contestants = cbNoContestans.Text.ToInteger
		  xScheduler.rounds = cbRounds.Text.ToInteger
		  xScheduler.qualifiers = cbqualifiers.Text.ToInteger
		  xScheduler.qualifiersType = cbqualType.Text
		  //-------Races
		  xScheduler.heats = cbHeats.Text.ToInteger
		  xScheduler.races = cbRaces.Text.ToInteger
		  xScheduler.laps = cbLaps.Text.ToInteger
		  xScheduler.run_time = cbTime.Index * 60 
		  xScheduler.Racers = cbNoRacers.Text.ToInteger
		  If cbRaceType.Text = "Timed" Then xScheduler.timed = True
		  
		  
		  'rScheduler.timed =  
		  
		  'xScheduler.Racers = RacerListbox.LastRowIndex+1
		  
		  if name <> "" then
		    xScheduler.name = Name
		    xScheduler.description = "HyperRacers @  " + DateTime.Now.SQLDateTime
		    
		  else
		    xScheduler.name = "HyperRacers " + Str(win_HyperRace.raceSchedule_counter)
		    xScheduler.description = "Race Schedule @  " + DateTime.Now.SQLDateTime
		    
		  end if
		  
		  If win_HyperRace.racers.LastIndex <0 Then
		    win_HyperRace.NewRacers
		    
		  end if
		  
		  win_HyperRace.NewScheduleTournament(xScheduler)        '(cbHeats.Text.ToInteger,cbRaces.Text.ToInteger,RacerListbox.LastRowIndex+1)
		  HRDBReload
		  'vHeat.Text = "1"
		  'vRace.Text = "1"
		  'vRound.Text = "1"
		  'vDay.Text = "1"
		  'vQualifier.Text = "1"
		  UpdateSchedule_win
		End Sub
	#tag EndMethod

	#tag Method, Flags = &h0
		Sub NewSchedulerDataBase(optional Name As String)
		  xScheduler = New RaceScheduler
		  
		  
		  win_HyperRace.raceSchedule_counter = win_HyperRace.raceSchedule_counter+ 1
		  
		  //-------Tournament
		  xScheduler.Tournamnets = cbTournaments.Text.ToInteger
		  xScheduler.raceClass = cbRaceClass.Text
		  xScheduler.dates = cbDates.Text.ToInteger
		  xScheduler.contestants = cbNoContestans.Text.ToInteger
		  xScheduler.rounds = cbRounds.Text.ToInteger
		  xScheduler.qualifiers = cbqualifiers.Text.ToInteger
		  xScheduler.qualifiersType = cbqualType.Text
		  //-------Races
		  xScheduler.heats = cbHeats.Text.ToInteger
		  xScheduler.races = cbRaces.Text.ToInteger
		  xScheduler.laps = cbLaps.Text.ToInteger
		  xScheduler.run_time = cbTime.Index * 60 
		  xScheduler.Racers = cbNoRacers.Text.ToInteger
		  if cbRaceType.Text = "Timed" then xScheduler.timed = true
		  
		  
		  'rScheduler.timed =  
		  
		  'xScheduler.Racers = RacerListbox.LastRowIndex+1
		  
		  if name <> "" then
		    xScheduler.name = Name
		    xScheduler.description = "HyperRacers @  " + DateTime.Now.SQLDateTime
		    
		  else
		    xScheduler.name = "HyperRacers " + Str(win_HyperRace.raceSchedule_counter)
		    xScheduler.description = "Race Schedule created @  " + DateTime.Now.SQLDateTime
		    
		  end if
		  
		  If win_HyperRace.racers.LastIndex <0 Then
		    win_HyperRace.NewRacers
		    
		  end if
		  
		  win_HyperRace.NewScheduleTournament(xScheduler)        '(cbHeats.Text.ToInteger,cbRaces.Text.ToInteger,RacerListbox.LastRowIndex+1)
		  HRDBReload
		  'vHeat.Text = "1"
		  'vRace.Text = "1"
		  'vRound.Text = "1"
		  'vDay.Text = "1"
		  'vQualifier.Text = "1"
		  UpdateSchedule_win
		End Sub
	#tag EndMethod

